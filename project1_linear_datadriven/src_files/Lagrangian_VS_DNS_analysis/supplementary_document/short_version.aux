\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:scattered}{{1}{2}{Scattered Lagrangian data (Approach~A, scheme 1). Left: rise velocity (solid = centroid, dashed = vol-avg; red = Eulerian, blue = Lagrangian). Right: circularity.\relax }{figure.caption.1}{}}
\newlabel{fig:scattered@cref}{{[figure][1][]1}{[1][1][]2}}
