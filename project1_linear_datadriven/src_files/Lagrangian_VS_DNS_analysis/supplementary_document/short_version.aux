\newlabel{fig:interpolated}{{2}{2}{Re-interpolated Lagrangian data (Approach~B, scheme 1). Left: rise velocity. Right: circularity. Both Lagrangian curves (blue) now closely track the Eulerian reference (red).\relax }{figure.caption.2}{}}
\newlabel{fig:interpolated@cref}{{[figure][2][]2}{[1][2][]2}}
